---
import { navItems, site } from "@/config/site";

type Props = {
  title?: string;
  description?: string;
};

const title = Astro.props.title ? `${Astro.props.title} | ${site.name}` : site.name;
const description = Astro.props.description || site.description;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#070B12" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="ambient" aria-hidden="true">
      <div class="orb orb-a"></div>
      <div class="orb orb-b"></div>
      <div class="orb orb-c"></div>
      <div class="grid-fade"></div>
      <div class="noise"></div>
    </div>

    <header class="site-header">
      <a class="brand" href="/" aria-label={`${site.name} home`}>
        <img src="/assets/logo.png" alt="" class="brand-mark" width="36" height="36" />
        <span class="brand-text">
          <strong>{site.name}</strong>
          <em>watchtower</em>
        </span>
      </a>
      <button class="menu-button" type="button" aria-label="Open navigation" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <nav class="site-nav" aria-label="Primary navigation">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
        <a class="nav-cta" href="/contact/">Request access</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <a class="brand" href="/" aria-label={`${site.name} home`}>
            <img src="/assets/logo.png" alt="" class="brand-mark" width="36" height="36" />
            <span class="brand-text">
              <strong>{site.name}</strong>
              <em>watchtower</em>
            </span>
          </a>
          <p>{site.description}</p>
          <div class="bifrost-line" aria-hidden="true"></div>
        </div>
        <div class="footer-columns">
          <div class="footer-column">
            <h3>Product</h3>
            <ul>
              <li><a href="/gateway/">Watchtower</a></li>
              <li><a href="/pricing/">Pricing</a></li>
              <li><a href="/docs/">Docs</a></li>
              <li><a href="/blog/">Blog</a></li>
            </ul>
          </div>
          <div class="footer-column">
            <h3>Company</h3>
            <ul>
              <li><a href="/">Home</a></li>
              <li><a href="/faq/">FAQ</a></li>
              <li><a href="/contact/">Contact</a></li>
            </ul>
          </div>
          <div class="footer-column">
            <h3>Legal</h3>
            <ul>
              <li><a href="/privacy/">Privacy</a></li>
              <li><a href="/terms/">Terms</a></li>
              <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
            </ul>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} {site.name}. Seeing growth before the crowd.</p>
      </div>
    </footer>

    <script>
      const button = document.querySelector(".menu-button");
      const nav = document.querySelector(".site-nav");
      button?.addEventListener("click", () => {
        const isOpen = nav?.classList.toggle("is-open") || false;
        button.setAttribute("aria-expanded", String(isOpen));
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --bg: #070b12;
    --bg-elevated: #0c1220;
    --bg-card: rgba(14, 22, 38, 0.72);
    --bg-card-solid: #101a2e;
    --ink: #f1f5f9;
    --ink-soft: #cbd5e1;
    --muted: #8b9bb4;
    --line: rgba(148, 163, 184, 0.14);
    --line-strong: rgba(148, 163, 184, 0.28);
    --cyan: #22d3ee;
    --indigo: #818cf8;
    --violet: #a78bfa;
    --amber: #fbbf24;
    --accent: #38bdf8;
    --accent-strong: #22d3ee;
    --accent-warm: #fbbf24;
    --success: #34d399;
    --danger: #fb7185;
    --shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
    --radius: 18px;
    --radius-sm: 12px;
    --font: "Plus Jakarta Sans", ui-sans-serif, system-ui, -apple-system, sans-serif;
    --mono: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    --bifrost: linear-gradient(120deg, #22d3ee 0%, #818cf8 45%, #fbbf24 100%);
    --glow-cyan: 0 0 40px rgba(34, 211, 238, 0.25);
    --header-h: 72px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: var(--bg);
    color: var(--ink);
    font-family: var(--font);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  body::selection {
    background: rgba(34, 211, 238, 0.28);
    color: #fff;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img,
  svg {
    max-width: 100%;
    display: block;
  }

  /* Ambient stage */
  .ambient {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
    background:
      radial-gradient(1200px 600px at 10% -10%, rgba(34, 211, 238, 0.12), transparent 55%),
      radial-gradient(900px 500px at 90% 0%, rgba(129, 140, 248, 0.14), transparent 50%),
      radial-gradient(800px 500px at 50% 100%, rgba(251, 191, 36, 0.06), transparent 55%),
      var(--bg);
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.55;
    animation: float 18s ease-in-out infinite;
  }

  .orb-a {
    width: 420px;
    height: 420px;
    top: -80px;
    left: -60px;
    background: rgba(34, 211, 238, 0.35);
  }

  .orb-b {
    width: 380px;
    height: 380px;
    top: 20%;
    right: -100px;
    background: rgba(129, 140, 248, 0.32);
    animation-delay: -6s;
  }

  .orb-c {
    width: 320px;
    height: 320px;
    bottom: 5%;
    left: 35%;
    background: rgba(251, 191, 36, 0.12);
    animation-delay: -11s;
  }

  .grid-fade {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(148, 163, 184, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 163, 184, 0.05) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 20%, black, transparent 75%);
    opacity: 0.45;
  }

  .noise {
    position: absolute;
    inset: 0;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  @keyframes float {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    50% {
      transform: translate3d(20px, 28px, 0) scale(1.06);
    }
  }

  /* Header */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    min-height: var(--header-h);
    padding: 12px clamp(18px, 4vw, 48px);
    border-bottom: 1px solid var(--line);
    background: rgba(7, 11, 18, 0.72);
    backdrop-filter: blur(18px) saturate(1.2);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }

  .brand-mark {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    object-fit: cover;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.08), var(--glow-cyan);
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
    gap: 2px;
  }

  .brand-text strong {
    font-size: 15px;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .brand-text em {
    font-style: normal;
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: clamp(14px, 1.6vw, 22px);
    font-size: 14px;
    font-weight: 600;
    color: var(--muted);
  }

  .site-nav a:not(.nav-cta):hover {
    color: var(--ink);
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 0 16px;
    border-radius: 999px;
    background: var(--bifrost);
    color: #061018 !important;
    font-weight: 750;
    box-shadow: var(--glow-cyan);
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  .nav-cta:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
  }

  .menu-button {
    display: none;
    width: 42px;
    height: 42px;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: rgba(16, 26, 46, 0.8);
    cursor: pointer;
  }

  .menu-button span {
    display: block;
    width: 16px;
    height: 2px;
    margin: 3px auto;
    border-radius: 2px;
    background: var(--ink);
  }

  /* Layout primitives */
  .section {
    padding: clamp(64px, 9vw, 112px) clamp(18px, 4vw, 48px);
  }

  .section-inner {
    width: min(1140px, 100%);
    margin: 0 auto;
  }

  .section.narrow .section-inner {
    width: min(760px, 100%);
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 16px;
    padding: 6px 12px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(14, 22, 38, 0.7);
    color: var(--cyan);
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .eyebrow::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--cyan);
    box-shadow: 0 0 12px var(--cyan);
  }

  h1,
  h2,
  h3,
  h4 {
    overflow-wrap: anywhere;
    letter-spacing: -0.03em;
    color: var(--ink);
  }

  h1 {
    max-width: 16ch;
    margin: 0;
    font-size: clamp(2.6rem, 6.5vw, 4.75rem);
    line-height: 0.98;
    font-weight: 800;
  }

  h2 {
    max-width: 20ch;
    margin: 0 0 16px;
    font-size: clamp(1.9rem, 3.8vw, 3rem);
    line-height: 1.08;
    font-weight: 750;
  }

  h3 {
    margin: 0 0 10px;
    font-size: 1.2rem;
    line-height: 1.25;
    font-weight: 700;
  }

  p {
    margin: 0;
    color: var(--muted);
  }

  .lead {
    max-width: 54ch;
    margin-top: 22px;
    color: var(--ink-soft);
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
    line-height: 1.65;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 48px;
    padding: 0 20px;
    border: 1px solid transparent;
    border-radius: 999px;
    background: var(--bifrost);
    color: #061018;
    font-weight: 750;
    font-size: 0.95rem;
    box-shadow: var(--glow-cyan);
    transition: transform 0.18s ease, filter 0.18s ease, background 0.18s ease;
    cursor: pointer;
  }

  .button:hover {
    transform: translateY(-1px);
    filter: brightness(1.06);
  }

  .button.secondary {
    background: transparent;
    border-color: var(--line-strong);
    color: var(--ink);
    box-shadow: none;
  }

  .button.secondary:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(34, 211, 238, 0.35);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .card {
    position: relative;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg-card);
    backdrop-filter: blur(16px);
    padding: 24px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  .card:hover {
    border-color: rgba(34, 211, 238, 0.35);
    transform: translateY(-2px);
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.28), 0 0 0 1px rgba(34, 211, 238, 0.08);
  }

  .band {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: linear-gradient(180deg, rgba(12, 18, 32, 0.55), rgba(7, 11, 18, 0.2));
  }

  .bifrost-line {
    height: 2px;
    width: min(180px, 40%);
    margin-top: 20px;
    border-radius: 999px;
    background: var(--bifrost);
    box-shadow: var(--glow-cyan);
  }

  /* Footer */
  .site-footer {
    position: relative;
    padding: 64px clamp(18px, 4vw, 48px) 28px;
    margin-top: 24px;
    border-top: 1px solid transparent;
  }

  .site-footer::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--bifrost);
    opacity: 0.7;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.4fr 2fr;
    gap: 3rem;
    width: min(1140px, 100%);
    margin: 0 auto;
  }

  .footer-brand p {
    max-width: 36ch;
    margin-top: 16px;
    line-height: 1.7;
  }

  .footer-columns {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .footer-column h3 {
    margin: 0 0 14px;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .footer-column ul {
    display: grid;
    gap: 10px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-column a {
    color: var(--muted);
    font-size: 0.95rem;
    transition: color 0.15s ease;
  }

  .footer-column a:hover {
    color: var(--cyan);
  }

  .footer-bottom {
    width: min(1140px, 100%);
    margin: 40px auto 0;
    padding-top: 20px;
    border-top: 1px solid var(--line);
    text-align: center;
    font-size: 0.85rem;
    color: var(--muted);
  }

  /* Links in content */
  .article-body a,
  .article-layout a,
  main .prose a {
    color: var(--cyan);
    text-decoration: underline;
    text-underline-offset: 0.18em;
    font-weight: 600;
  }

  .article-body a:hover,
  .article-layout a:hover {
    color: var(--amber);
  }

  .article-body {
    max-width: 720px;
  }

  .article-body h1 {
    max-width: none;
    margin: 0 0 1.1rem;
    font-size: clamp(2rem, 4.5vw, 2.75rem);
    line-height: 1.12;
  }

  .article-body h2 {
    max-width: none;
    margin: 2.1rem 0 0.9rem;
    font-size: clamp(1.45rem, 3vw, 1.85rem);
  }

  .article-body h3 {
    margin: 1.6rem 0 0.7rem;
    font-size: 1.25rem;
  }

  .article-body p,
  .article-body li {
    color: var(--ink-soft);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .article-body p {
    margin: 0 0 1.15rem;
  }

  .article-body ul,
  .article-body ol {
    margin: 0 0 1.15rem;
    padding-left: 1.35rem;
  }

  .article-body li {
    margin-bottom: 0.45rem;
  }

  .article-body table {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 1.4rem;
    font-size: 0.95rem;
  }

  .article-body th,
  .article-body td {
    border: 1px solid var(--line);
    padding: 0.65rem 0.8rem;
    text-align: left;
  }

  .article-body th {
    background: rgba(34, 211, 238, 0.06);
    color: var(--ink);
  }

  .article-body img {
    border-radius: 14px;
    margin: 1.4rem 0;
    border: 1px solid var(--line);
  }

  .breadcrumbs {
    width: min(1140px, 100%);
    margin: 0 auto;
    padding: 1rem clamp(18px, 4vw, 48px) 0;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .breadcrumbs li:not(:last-child)::after {
    content: "/";
    margin-left: 0.45rem;
    color: var(--muted);
    opacity: 0.6;
  }

  .breadcrumbs a {
    color: var(--cyan);
  }

  .breadcrumbs [aria-current="page"] {
    display: inline-block;
    max-width: min(420px, 60vw);
    font-weight: 600;
    color: var(--ink-soft);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    vertical-align: bottom;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .footer-columns {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 780px) {
    .menu-button {
      display: grid;
    }

    .site-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 8px 18px 18px;
      border-bottom: 1px solid var(--line);
      background: rgba(7, 11, 18, 0.96);
      backdrop-filter: blur(16px);
    }

    .site-nav.is-open {
      display: flex;
    }

    .site-nav a {
      border-top: 1px solid var(--line);
      padding: 14px 0;
    }

    .nav-cta {
      justify-content: center;
      margin-top: 8px;
    }

    h1 {
      max-width: none;
    }
  }

  @media (max-width: 480px) {
    .footer-columns {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .orb {
      animation: none;
    }
    .button,
    .card,
    .nav-cta {
      transition: none;
    }
  }
</style>
