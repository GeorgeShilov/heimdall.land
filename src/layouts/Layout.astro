---
import { navItems, site } from "@/config/site";

type Props = {
  title?: string;
  description?: string;
};

const title = Astro.props.title ? `${Astro.props.title} | ${site.name}` : site.name;
const description = Astro.props.description || site.description;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label={`${site.name} home`}>
        <span class="brand-mark">H</span>
        <span>{site.name}</span>
      </a>
      <button class="menu-button" type="button" aria-label="Open navigation" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <nav class="site-nav" aria-label="Primary navigation">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <a class="brand footer-brand" href="/">
          <span class="brand-mark">H</span>
          <span>{site.name}</span>
        </a>
        <p>
          Heimdall can see cryptocurrency as it grows. A watchtower for decentralized networks.
        </p>
      </div>
      <div class="footer-links">
        <a href="/privacy/">Privacy</a>
        <a href="/terms/">Terms</a>
        <a href="/contact/">Contact</a>
      </div>
    </footer>
    <script>
      const button = document.querySelector(".menu-button");
      const nav = document.querySelector(".site-nav");
      button?.addEventListener("click", () => {
        const isOpen = nav?.classList.toggle("is-open") || false;
        button.setAttribute("aria-expanded", String(isOpen));
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --bg-deep: #0A0A0F;
    --bg-card: rgba(17, 17, 24, 0.6);
    --ink: #F8FAFC;
    --muted: #94A3B8;
    --line: rgba(99, 102, 241, 0.2);
    --accent: #6366F1;
    --accent-secondary: #A855F7;
    --shadow: 0 18px 50px rgba(0, 0, 0, 0.4);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg-deep);
    color: var(--ink);
    line-height: 1.6;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img,
  svg {
    max-width: 100%;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 16px clamp(18px, 5vw, 64px);
    border-bottom: 1px solid var(--line);
    background: rgba(10, 10, 15, 0.85);
    backdrop-filter: blur(18px);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    letter-spacing: 0;
    white-space: nowrap;
    color: var(--ink);
  }

  .brand-mark {
    display: grid;
    width: 34px;
    height: 34px;
    place-items: center;
    border-radius: 8px;
    background: linear-gradient(135deg, #6366F1, #A855F7);
    color: #fff;
    font-size: 17px;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: clamp(14px, 2vw, 26px);
    color: var(--muted);
    font-size: 15px;
    font-weight: 650;
  }

  .site-nav a:hover {
    color: var(--ink);
  }

  .menu-button {
    display: none;
    width: 42px;
    height: 42px;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(17, 17, 24, 0.8);
  }

  .menu-button span {
    display: block;
    width: 18px;
    height: 2px;
    margin: 3px auto;
    background: var(--ink);
  }

  .section {
    padding: clamp(58px, 8vw, 104px) clamp(18px, 5vw, 64px);
  }

  .section-inner {
    width: min(1120px, 100%);
    margin: 0 auto;
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--accent-secondary);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1 {
    max-width: 900px;
    margin: 0;
    font-size: clamp(42px, 8vw, 88px);
    line-height: 0.96;
    letter-spacing: 0;
    color: var(--ink);
  }

  h2 {
    max-width: 780px;
    margin: 0 0 18px;
    font-size: clamp(30px, 4vw, 52px);
    line-height: 1.05;
    letter-spacing: 0;
    color: var(--ink);
  }

  h3 {
    margin: 0 0 10px;
    font-size: 21px;
    line-height: 1.2;
    color: var(--ink);
  }

  p {
    margin: 0;
    color: var(--muted);
  }

  .lead {
    max-width: 720px;
    margin-top: 24px;
    color: #cbd5e1;
    font-size: clamp(18px, 2vw, 22px);
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 34px;
  }

  .button {
    display: inline-flex;
    min-height: 46px;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    padding: 12px 18px;
    border: 1px solid transparent;
    background: linear-gradient(135deg, #6366F1, #A855F7);
    color: #fff;
    font-weight: 760;
    transition: opacity 0.2s, transform 0.2s;
  }

  .button:hover {
    opacity: 0.92;
    transform: translateY(-1px);
  }

  .button.secondary {
    border-color: var(--line);
    background: transparent;
    color: var(--ink);
  }

  .button.secondary:hover {
    background: rgba(99, 102, 241, 0.1);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .card {
    border: 1px solid var(--line);
    border-radius: 16px;
    background: var(--bg-card);
    backdrop-filter: blur(16px);
    padding: 24px;
    box-shadow: 0 1px 0 rgba(99, 102, 241, 0.05);
    transition: all 0.3s ease;
  }

  .card:hover {
    border-color: rgba(99, 102, 241, 0.5);
    box-shadow: 0 0 30px rgba(99, 102, 241, 0.15);
  }

  .band {
    background: rgba(17, 17, 24, 0.4);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    gap: 32px;
    padding: 44px clamp(18px, 5vw, 64px);
    border-top: 1px solid transparent;
    background: var(--bg-deep);
    position: relative;
  }

  .site-footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), var(--accent-secondary), transparent);
  }

  .site-footer p {
    max-width: 520px;
    margin-top: 12px;
    color: var(--muted);
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    align-content: flex-start;
    gap: 16px;
    color: var(--muted);
    font-weight: 650;
  }

  .footer-links a:hover {
    color: var(--ink);
  }

  .article-body {
    max-width: 760px;
  }

  .article-body p,
  .article-body li {
    color: #cbd5e1;
    font-size: 18px;
  }

  .article-body p + p,
  .article-body ul + p {
    margin-top: 20px;
  }

  .article-body code,
  pre {
    white-space: pre-wrap;
    word-break: break-word;
  }

  @media (max-width: 780px) {
    .site-header {
      align-items: center;
      flex-wrap: nowrap;
      gap: 12px;
    }

    .menu-button {
      display: grid;
      flex-shrink: 0;
    }

    .site-nav {
      display: none;
      width: 100%;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding-top: 8px;
    }

    .site-nav.is-open {
      display: flex;
    }

    .site-nav a {
      border-top: 1px solid var(--line);
      padding: 12px 0;
    }

    .grid {
      grid-template-columns: 1fr;
    }

    .site-footer {
      flex-direction: column;
    }
  }
</style>
