---
/**
 * Card for blog index. `slug` must be the content-collection entry slug
 * (filename stem) so URLs stay https://heimdall.land/blog/{slug}/.
 */
export type PostCardData = {
  slug: string;
  title: string;
  description: string;
  pubDate: Date | string;
  category: string;
  tags: string[];
  heroImage?: string;
};

const { post } = Astro.props as { post: PostCardData };
const hero = post.heroImage || "/assets/archive-grid.svg";
const pub = post.pubDate instanceof Date ? post.pubDate : new Date(post.pubDate);
const dateLabel = pub.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<article class="post-card">
  <a class="post-media" href={`/blog/${post.slug}/`} tabindex="-1" aria-hidden="true">
    <img src={hero} alt="" loading="lazy" width="640" height="360" />
  </a>
  <div class="post-body">
    <p class="meta">
      <span class="cat">{post.category}</span>
      <time datetime={pub.toISOString()}>{dateLabel}</time>
    </p>
    <h3>
      <a href={`/blog/${post.slug}/`}>{post.title}</a>
    </h3>
    <p class="desc">{post.description}</p>
    {
      post.tags?.length > 0 && (
        <div class="tags">
          {post.tags.slice(0, 4).map((tag) => (
            <span>{tag}</span>
          ))}
        </div>
      )
    }
    <a class="read" href={`/blog/${post.slug}/`}>Read note →</a>
  </div>
</article>

<style>
  .post-card {
    display: grid;
    grid-template-rows: 180px 1fr;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg-card);
    backdrop-filter: blur(16px);
    transition:
      border-color 0.25s ease,
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  .post-card:hover {
    border-color: rgba(34, 211, 238, 0.4);
    transform: translateY(-3px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(34, 211, 238, 0.08);
  }

  .post-media {
    display: block;
    overflow: hidden;
    background: #0a1220;
  }

  .post-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
  }

  .post-card:hover .post-media img {
    transform: scale(1.04);
  }

  .post-body {
    display: grid;
    gap: 12px;
    align-content: start;
    padding: 20px 20px 22px;
  }

  .meta {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    margin: 0;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .cat {
    color: var(--cyan);
  }

  h3 {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.3;
  }

  h3 a:hover {
    color: var(--cyan);
  }

  .desc {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tags span {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 4px 10px;
    color: var(--ink-soft);
    font-size: 12px;
    font-weight: 600;
  }

  .read {
    margin-top: 4px;
    color: var(--cyan);
    font-weight: 700;
    font-size: 0.92rem;
  }

  .read:hover {
    color: var(--amber);
  }
</style>
