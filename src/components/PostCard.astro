---
import type { BlogPost } from "@/data/blog";

const { post } = Astro.props as { post: BlogPost };
---

<article class="post-card">
  <img src={post.heroImage} alt="" loading="lazy" />
  <div>
    <p class="meta">{post.category} / {new Date(post.pubDate).toLocaleDateString("ru-RU")}</p>
    <h3><a href={`/blog/${post.slug}/`}>{post.title}</a></h3>
    <p>{post.description}</p>
    <div class="tags">
      {post.tags.map((tag) => <span>{tag}</span>)}
    </div>
  </div>
</article>

<style>
  .post-card {
    display: grid;
    grid-template-rows: 180px 1fr;
    overflow: hidden;
    border: 1px solid rgba(251, 191, 36, 0.2);
    border-radius: 16px;
    background: rgba(17, 24, 39, 0.7);
    backdrop-filter: blur(16px);
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    background: rgba(17, 24, 39, 0.8);
  }

  div {
    padding: 22px;
  }

  .meta {
    margin-bottom: 10px;
    color: #fbbf24;
    font-size: 13px;
    font-weight: 800;
  }

  h3 a:hover { color: var(--accent); text-decoration: underline; }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
    padding: 0;
  }

  span {
    border: 1px solid rgba(251, 191, 36, 0.2);
    border-radius: 999px;
    padding: 4px 9px;
    color: #fcd34d;
    font-size: 12px;
    font-weight: 700;
  }
</style>
