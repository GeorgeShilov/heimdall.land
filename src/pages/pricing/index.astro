---
import Layout from "@/layouts/Layout.astro";

const plans = [
  {
    name: "Signal",
    price: "$490",
    period: "one-time",
    description: "Single-page security audit, API gateway health check, basic anomaly alerts, and email support.",
    features: [
      "Single-page security audit",
      "API gateway health check",
      "Basic anomaly alerts",
      "Email support",
    ],
    cta: "Get Signal",
    popular: false,
  },
  {
    name: "Command",
    price: "$1,400",
    period: "one-time",
    description: "Full watchtower coverage, continuous node monitoring, advanced threat detection, and priority support.",
    features: [
      "Everything in Signal",
      "Continuous node monitoring",
      "Advanced threat detection",
      "Webhook & Slack alerts",
      "Priority support",
    ],
    cta: "Get Command",
    popular: true,
  },
  {
    name: "Scale",
    price: "Custom",
    period: "annual",
    description: "Railway backend, data integrations, content workflow, analytics, and iteration support.",
    features: [
      "Everything in Command",
      "Custom sentinel rules",
      "Multi-chain coverage",
      "Dedicated account manager",
      "SLA guarantee",
    ],
    cta: "Contact sales",
    popular: false,
  },
];
---

<Layout title="Pricing">
  <section class="section pricing-hero">
    <div class="section-inner">
      <p class="eyebrow">Pricing</p>
      <h1>Pick the command layer.</h1>
      <p class="lead">
        Start with focused signal coverage, then add continuous monitoring, multi-chain tracking, and
        custom sentinel rules as your network footprint grows.
      </p>

      <div class="grid pricing-grid">
        {plans.map((plan) => (
          <article class={`pricing-card ${plan.popular ? "popular" : ""}`}>
            {plan.popular && <div class="popular-badge">Most Popular</div>}
            <div class="pricing-header">
              <h3>{plan.name}</h3>
              <p class="pricing-desc">{plan.description}</p>
              <div class="pricing-price">
                <strong>{plan.price}</strong>
                <span>{plan.period}</span>
              </div>
            </div>
            <ul class="pricing-features">
              {plan.features.map((feature) => (
                <li>
                  <span class="check">✓</span>
                  {feature}
                </li>
              ))}
            </ul>
            <a class={`pricing-cta ${plan.popular ? "primary" : "secondary"}`} href="/contact/">
              {plan.cta}
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .pricing-hero {
    background:
      radial-gradient(ellipse 60% 40% at 50% 0%, rgba(99, 102, 241, 0.08), transparent),
      linear-gradient(180deg, #0A0A0F 0%, #111118 100%);
  }

  .pricing-grid {
    margin-top: 56px;
    align-items: start;
  }

  .pricing-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 32px 28px;
    border: 1px solid rgba(99, 102, 241, 0.2);
    border-radius: 20px;
    background: rgba(17, 17, 24, 0.6);
    backdrop-filter: blur(16px);
    transition: all 0.3s ease;
  }

  .pricing-card:hover {
    border-color: rgba(99, 102, 241, 0.4);
    box-shadow: 0 0 40px rgba(99, 102, 241, 0.1);
  }

  .pricing-card.popular {
    border: 1px solid transparent;
    background: linear-gradient(#111118, #111118) padding-box,
      linear-gradient(135deg, #6366F1, #A855F7) border-box;
    box-shadow: 0 0 50px rgba(99, 102, 241, 0.2);
    transform: translateY(-8px);
  }

  .popular-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    padding: 6px 16px;
    border-radius: 100px;
    background: linear-gradient(135deg, #6366F1, #A855F7);
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .pricing-header h3 {
    font-size: 24px;
    font-weight: 700;
    margin: 0 0 10px;
    color: #F8FAFC;
  }

  .pricing-desc {
    color: #94A3B8;
    font-size: 15px;
    line-height: 1.5;
    margin: 0 0 20px;
  }

  .pricing-price {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .pricing-price strong {
    font-size: 36px;
    font-weight: 800;
    color: #F8FAFC;
    margin: 0;
  }

  .pricing-price span {
    color: #94A3B8;
    font-size: 14px;
  }

  .pricing-features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pricing-features li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #cbd5e1;
    font-size: 15px;
    line-height: 1.4;
  }

  .check {
    display: grid;
    width: 20px;
    height: 20px;
    place-items: center;
    border-radius: 50%;
    background: rgba(99, 102, 241, 0.2);
    color: #6366F1;
    font-size: 11px;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .pricing-cta {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    padding: 12px 20px;
    font-weight: 700;
    font-size: 15px;
    transition: all 0.2s ease;
    margin-top: auto;
  }

  .pricing-cta.primary {
    background: linear-gradient(135deg, #6366F1, #A855F7);
    color: #fff;
    border: none;
  }

  .pricing-cta.primary:hover {
    opacity: 0.92;
    transform: translateY(-1px);
  }

  .pricing-cta.secondary {
    border: 1px solid rgba(99, 102, 241, 0.3);
    background: transparent;
    color: #F8FAFC;
  }

  .pricing-cta.secondary:hover {
    background: rgba(99, 102, 241, 0.1);
    border-color: rgba(99, 102, 241, 0.5);
  }

  @media (max-width: 780px) {
    .pricing-card.popular {
      transform: none;
    }
  }
</style>
