---
import Layout from "@/layouts/Layout.astro";

const faqs = [
  ["What does Heimdall track?", "Price velocity, on-chain transaction volume, active address trends, network hash rate, validator health, and decentralization metrics across Bitcoin, Ethereum, and emerging chains."],
  ["Where does the data come from?", "Heimdall connects directly to blockchain nodes rather than centralized APIs. This keeps data fresh, independent, and censorship-resistant."],
  ["Which networks are supported?", "Bitcoin and Ethereum are fully supported. Emerging proof-of-stake networks and Layer-2 protocols are added as they reach sufficient node distribution."],
  ["Is Heimdall a trading platform?", "No. Heimdall is a research and tracking tool. We provide visibility into network growth and health, not buy or sell recommendations."]
];
---

<Layout title="FAQ">
  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">FAQ</p>
      <h1>Common questions about the watchtower.</h1>
      <div class="faq-list">
        {faqs.map(([question, answer]) => (
          <details class="card">
            <summary>{question}</summary>
            <p>{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .faq-list {
    display: grid;
    gap: 14px;
    margin-top: 40px;
  }

  summary {
    cursor: pointer;
    font-weight: 800;
    font-size: 20px;
  }

  details p {
    margin-top: 14px;
  }
</style>
