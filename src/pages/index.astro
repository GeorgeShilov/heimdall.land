---
import Layout from '@/layouts/Layout.astro'; import LeadDialog from '@/components/LeadDialog.astro';
---
<Layout title="Open-world cartography"><div class="atlas"><section class="map"><nav><b>HEIMDALL.LAND</b><span>Cartographic observatory</span><button data-lead>Join an expedition</button></nav><img src="/assets/generated/hero-observatory.jpg" alt="Fantasy cartographic observatory landscape"/><div class="coordinates">64°08′N<br/>21°56′W</div><div class="map-title"><p>Field atlas / volume 04</p><h1>Map the worlds<br/>worth entering.</h1></div><ul class="legend"><li><i class="gold"/>Discovered</li><li><i class="blue"/>Under survey</li><li><i/>Unknown</li></ul></section><section class="log"><header><p>EXPEDITION LOG</p><h2>Every place begins as a question.</h2></header><article><span>01</span><div><h3>Observe</h3><p>Read the culture, systems and strange edges of a world.</p></div></article><article><span>02</span><div><h3>Chart</h3><p>Turn scattered signals into a legible field guide.</p></div></article><article><span>03</span><div><h3>Gather</h3><p>Bring explorers, builders and stories onto the same map.</p></div></article></section><section class="crew"><div><small>THE OBSERVATORY CREW</small><h2>Human eyes on digital terrain.</h2><p>Researchers, mapmakers and world-builders working between geography, games and online culture.</p><button data-lead>Send a signal</button></div><img src="/assets/generated/mapping-team.jpg" alt="Mapping team in a modern observatory"/></section><LeadDialog /></div></Layout>
<style>:global(.site-header),:global(.site-footer){display:none}.atlas{background:#e9e4d5;color:#15261f;font-family:Arial,sans-serif}.map{position:relative;height:100vh;overflow:hidden}.map>img{width:100%;height:100%;object-fit:cover;filter:saturate(.72) contrast(1.1)}.map nav{position:absolute;z-index:2;top:0;left:0;right:0;display:flex;justify-content:space-between;padding:24px 4vw;color:white;border-bottom:1px solid #ffffff66}.map nav button,.crew button{border:1px solid currentColor;border-radius:100px;background:transparent;color:inherit;padding:10px 18px}.map-title{position:absolute;bottom:8vw;left:5vw;color:white}.map-title h1{font-family:Georgia,serif;font-size:clamp(4rem,9vw,9rem);line-height:.86;margin:.15em 0;text-shadow:0 4px 30px #0006}.coordinates{position:absolute;right:4vw;top:22%;background:#e9e4d5;padding:18px;font-weight:700}.legend{position:absolute;right:4vw;bottom:6vw;background:#e9e4d5;padding:20px 28px;list-style:none}.legend i{display:inline-block;width:10px;height:10px;border-radius:50%;background:#182a24;margin-right:10px}.legend .gold{background:#d29c35}.legend .blue{background:#4d7c8d}.log{display:grid;grid-template-columns:1.6fr repeat(3,1fr);padding:8vw 4vw}.log>*{padding:24px;border-left:1px solid #647269}.log h2{font:3.5rem Georgia,serif}.log article span{font-size:4rem;color:#a99058}.crew{display:grid;grid-template-columns:1fr 1.2fr;background:#183229;color:#eee9dc;align-items:center}.crew div{padding:7vw}.crew h2{font:clamp(3rem,6vw,6rem)/.95 Georgia,serif}.crew img{width:100%;height:650px;object-fit:cover}@media(max-width:760px){.map nav span{display:none}.legend{display:none}.log{grid-template-columns:1fr}.log>*{border-left:0;border-top:1px solid}.crew{grid-template-columns:1fr}.crew img{height:440px}}</style>
