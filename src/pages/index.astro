---
import ArchiveNotice from "@/components/ArchiveNotice.astro";
import PostCard from "@/components/PostCard.astro";
import Layout from "@/layouts/Layout.astro";
import { site } from "@/config/site";
import { getBlogPosts } from "@/lib/squidex";

const posts = await getBlogPosts();
const sorted = [...posts].sort(
  (a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime()
);
const latest3 = sorted.slice(0, 3);

const features = [
  {
    icon: "◈",
    title: "Growth Tracking",
    description:
      "See cryptocurrency as it grows. Track price movements, network adoption, and on-chain metrics across Bitcoin, Ethereum, and emerging assets.",
  },
  {
    icon: "◉",
    title: "Decentralized Vision",
    description:
      "Built for a future where individuals interact without depending on third parties. Bitcoin and cryptocurrencies as the foundation of a new era.",
  },
  {
    icon: "◆",
    title: "Network Insight",
    description:
      "Watch validator health, transaction flows, and protocol upgrades across decentralized networks from a single clear vantage point.",
  },
];

const testimonials = [
  {
    initials: "MK",
    name: "Marcus Kowalski",
    role: "Early Bitcoin Adopter",
    text: "Heimdall helped me spot the 2020 altcoin growth patterns months before they hit mainstream radar. The network insight is unlike anything else.",
  },
  {
    initials: "LP",
    name: "Lena Park",
    role: "DeFi Researcher, BlockScope",
    text: "The way Heimdall visualizes on-chain growth across multiple protocols is exactly what decentralized research needs. No third-party filters, just raw signal.",
  },
  {
    initials: "TR",
    name: "Tariq Rahman",
    role: "Crypto Fund Analyst",
    text: "I use Heimdall to track validator behavior and protocol adoption curves. It is the closest thing to having a watchtower over the entire decentralized landscape.",
  },
];
---

<Layout title="Heimdall / Cryptocurrency growth tracker" description={site.description}>
  <ArchiveNotice />

  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Heimdall / See cryptocurrency as it grows</p>
      <h1>Watch the decentralized landscape unfold.</h1>
      <p class="lead">
        Heimdall is a cryptocurrency growth tracker and decentralized network watchtower.
        We believe in a future where individuals interact without third parties — and we built
        the lens that lets you see that future forming in real time.
      </p>
      <div class="button-row">
        <a class="button" href="/gateway/">Explore the watchtower</a>
        <a class="button secondary" href="/blog/">Read field notes</a>
      </div>
    </div>
    <div class="hero-panel" aria-label="Heimdall cryptocurrency summary">
      <div>
        <span>Core view</span>
        <strong>Cryptocurrency growth tracking</strong>
      </div>
      <div>
        <span>Signals</span>
        <strong>Price, adoption, network health</strong>
      </div>
      <div>
        <span>Guard stack</span>
        <strong>Bitcoin, Ethereum, emerging chains</strong>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="section-inner split">
      <div>
        <p class="eyebrow">Why it exists</p>
        <h2>Infrastructure needs a watcher before it needs a witness.</h2>
      </div>
      <div class="history-list">
        {site.launchContext.map((item) => <p>{item}</p>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">Command architecture</p>
      <h2>One view for the messy first mile of growth.</h2>
      <div class="grid features-grid">
        {features.map((f) => (
          <article class="card feature-card">
            <div class="feature-icon">{f.icon}</div>
            <h3>{f.title}</h3>
            <p>{f.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="section-inner">
      <p class="eyebrow">Trusted by the network</p>
      <h2>Teams that see clearer with Heimdall.</h2>
      <div class="grid testimonials-grid">
        {testimonials.map((t) => (
          <article class="card testimonial-card">
            <div class="testimonial-header">
              <div class="avatar">{t.initials}</div>
              <div>
                <strong class="testimonial-name">{t.name}</strong>
                <span class="testimonial-role">{t.role}</span>
              </div>
            </div>
            <p class="testimonial-text">"{t.text}"</p>
            <div class="stars">★★★★★</div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {latest3.length > 0 && (
    <section class="section band">
      <div class="section-inner">
        <p class="eyebrow">Latest field notes</p>
        <h2>Fresh research from the decentralized frontier.</h2>
        <div class="latest-row">
          {latest3.map((post) => <PostCard post={post} />)}
        </div>
      </div>
    </section>
  )}
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
    gap: clamp(28px, 5vw, 72px);
    min-height: calc(100vh - 68px);
    align-items: center;
    padding: clamp(58px, 8vw, 110px) clamp(18px, 5vw, 64px) clamp(42px, 6vw, 80px);
    background:
      radial-gradient(ellipse 80% 50% at 20% 40%, rgba(251, 191, 36, 0.15), transparent),
      radial-gradient(ellipse 60% 40% at 80% 60%, rgba(249, 115, 22, 0.1), transparent),
      linear-gradient(180deg, #0a0f1a 0%, #111827 100%);
    color: #fff;
  }

  .hero-copy {
    max-width: 860px;
  }

  .hero .lead {
    color: rgba(255, 255, 255, 0.78);
  }

  .hero-panel {
    display: grid;
    gap: 12px;
    padding: 18px;
    border: 1px solid rgba(251, 191, 36, 0.2);
    border-radius: 16px;
    background: rgba(17, 24, 39, 0.7);
    backdrop-filter: blur(16px);
    box-shadow: 0 0 40px rgba(251, 191, 36, 0.1);
  }

  .hero-panel div {
    border-bottom: 1px solid rgba(251, 191, 36, 0.15);
    padding: 14px;
  }

  .hero-panel div:last-child {
    border-bottom: 0;
  }

  .hero-panel span {
    display: block;
    color: #fcd34d;
    font-size: 13px;
    font-weight: 800;
  }

  .hero-panel strong {
    display: block;
    margin-top: 5px;
    color: #fffbeb;
    font-size: 20px;
    line-height: 1.2;
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 36px;
  }

  .history-list {
    display: grid;
    gap: 16px;
  }

  .history-list p {
    border-left: 4px solid #fbbf24;
    padding-left: 16px;
    color: #fffbeb;
  }

  .features-grid {
    margin-top: 42px;
  }

  .feature-card {
    position: relative;
    overflow: hidden;
  }

  .feature-icon {
    display: grid;
    width: 48px;
    height: 48px;
    place-items: center;
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(251, 191, 36, 0.2), rgba(249, 115, 22, 0.2));
    color: #f97316;
    font-size: 22px;
    margin-bottom: 18px;
    border: 1px solid rgba(251, 191, 36, 0.2);
  }

  .testimonials-grid {
    margin-top: 42px;
  }

  .testimonial-card {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .testimonial-header {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .avatar {
    display: grid;
    width: 48px;
    height: 48px;
    place-items: center;
    border-radius: 50%;
    background: linear-gradient(135deg, #fbbf24, #f97316);
    color: #fff;
    font-size: 16px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .testimonial-name {
    display: block;
    color: #fffbeb;
    font-size: 16px;
    font-weight: 600;
  }

  .testimonial-role {
    display: block;
    color: #fcd34d;
    font-size: 14px;
  }

  .testimonial-text {
    color: #cbd5e1;
    font-style: italic;
    line-height: 1.6;
  }

  .stars {
    color: #fbbf24;
    font-size: 16px;
    letter-spacing: 2px;
  }

  .latest-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    margin-top: 36px;
  }

  @media (max-width: 860px) {
    .hero,
    .split {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
    }

    .latest-row {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }
</style>
