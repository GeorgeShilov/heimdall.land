---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Privacy">
  <section class="section">
    <div class="section-inner article-body">
      <p class="eyebrow">Privacy</p>
      <h1>Privacy policy</h1>
      <p>
        Heimdall does not require user accounts, payment forms, or customer dashboards. If you
        email the Heimdall contact address, your message and address are used only to respond.
      </p>
      <p>
        Hosting providers may collect standard server logs such as IP address, user agent, request
        path, and timestamp for security and operations. Blog content and visuals are managed
        through the content management system configured for the site.
      </p>
    </div>
  </section>
</Layout>
